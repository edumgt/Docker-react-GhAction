# Copy this file to .env and fill in the values before running docker compose.

# ── App ──────────────────────────────────────────────────────────────
# JWT signing secret — MUST be changed in production.
# Use a cryptographically random string of at least 32 characters.
# Generate one with: openssl rand -hex 32
JWT_SECRET=change-this-secret-in-production-use-a-long-random-string

# ── MariaDB ───────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=canvasdb
MYSQL_USER=canvasuser
MYSQL_PASSWORD=canvaspass
